# ── Polygon / Polymarket ───────────────────────────────────────
POLYGON_PRIVATE_KEY=0xyour_private_key_here
POLYMARKET_API_KEY=your_polymarket_api_key

# ── SkillPay Billing ───────────────────────────────────────────
# Get your API key at: https://skillpay.me → Dashboard → Integration Config
SKILLPAY_API_KEY=sk_your_key_here

# ── SkillPay User ID ───────────────────────────────────────────
# Use your Telegram ID (number) OR your wallet address (0x...)
# Example: 123456789  OR  0xAbCd...
SKILLPAY_USER_ID=your_telegram_id_or_wallet

# ── AI (Optional — Max tier) ───────────────────────────────────
# Get key at: https://openrouter.ai
# Leave empty to use SkillPay-powered AI (Pro tier)
OPENROUTER_API_KEY=

# ── Strategy Settings ─────────────────────────────────────────
# V3 wallet tracking: comma-separated Polygon addresses
TRACK_WALLETS=

# ── Dashboard ─────────────────────────────────────────────────
DASHBOARD_PORT=7799
