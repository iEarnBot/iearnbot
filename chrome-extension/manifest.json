{
  "manifest_version": 3,
  "name": "iEarn.Bot",
  "version": "0.4.0",
  "description": "AI-powered trading strategy generator & bot monitor. Generate strategies from any webpage, monitor your Polymarket positions.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "iEarn.Bot",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://polymarket.com/*", "https://kalshi.com/*", "https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://iearn.bot/*"
  ]
}
